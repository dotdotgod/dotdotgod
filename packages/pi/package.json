{
  "name": "@dotdotgod/pi",
  "version": "0.1.2",
  "description": "Pi adapter for dotdotgod: shared docs initialization, plan/archive workflow, and project loading extensions.",
  "type": "module",
  "license": "Elastic-2.0",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "ai-agent",
    "project-memory",
    "agent-memory",
    "documentation",
    "skill",
    "extension",
    "project-initializer",
    "plan-mode",
    "project-loader",
    "context-loader"
  ],
  "scripts": {
    "verify": "node --check extensions/load-project/index.ts && node --check extensions/plan-mode/index.ts && node --check extensions/plan-mode/utils.ts",
    "pack:dry-run": "npm pack --dry-run --json"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "pi": {
    "skills": [
      "./skills"
    ],
    "extensions": [
      "./extensions"
    ]
  },
  "files": [
    "skills",
    "extensions",
    "README.md",
    "LICENSE"
  ]
}
